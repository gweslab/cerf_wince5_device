; @CESYSGEN IF CE_MODULES_NE2000
IF BSP_NOPCIBUS !
IF BSP_NOETHER !
IF BSP_NIC_NE2000_PCI
; These are the registry settings for using the Kingston PCI NE2000 ethernet
; adapter on a CEPC.

;
; NE2000 Miniport driver information
;
[HKEY_LOCAL_MACHINE\Comm\NE2000]
;LOC_FRIENDLYNE2000COMPAT
   "DisplayName"=mui_sz:"netmui.dll,#9001"
   "Group"="NDIS"
   "ImagePath"="ne2000.dll"

;
; Template the PCI bus driver uses to match a Kingston NE2000 card
;
[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\PCI\Template\NE2000]
   "Dll"="NDIS.dll"
   "Class"=dword:02
   "SubClass"=dword:00
   "ProgIF"=dword:0
   "VendorID"=multi_sz:"10ec","1050"
   "DeviceID"=multi_sz:"8029","0940"
;  "Entry"="NdisPCIBusDeviceInit"
   "Prefix"="NDS"
   "Transceiver"=dword:3
;
; Installable shared ISR handler for the NE2000.
; Uses the generic ISR handler, configured to read
; IO port 7 (the ISR status register) and look at
; bitmask 0x1B (RCV, XMIT, XMIT_ERR, OVERRUN)
; to determine if the NE2000
; is indicating an interrupt.
;
; NOTE: The interrupt mask register of the NE2000
; is write-only.  Proper detection of whether an
; NE2000 adapter is generating an interrupt would
; require reading that mask. Since that is impossible,
; this shared ISR handler can incorrectly report
; that the device generated an interrupt when it did
; not.  Thus, it is not recommended that NE2000 adapters
; share interrupts with other devices.
;

;   "IsrDll"="giisr.dll"
;   "IsrHandler"="ISRHandler"
;   "PortIsIO"=dword:1
;   "PortOffset"=dword:7
;   "PortSize"=dword:1
;   "PortMask"=dword:1B

;;;
;;;  NE2000 miniport driver now has its own ISR (ne2000isr.dll)
;;;  The parameters needed for GIISR.DLL (common ISR handler) are not
;;;  needed anymore.
;;;  The ISR is loaded by NE2000.DLL miniport driver.
;;;


ENDIF BSP_NIC_NE2000_PCI
ENDIF BSP_NOETHER !
ENDIF BSP_NOPCIBUS !
; @CESYSGEN ENDIF CE_MODULES_NE2000


; @CESYSGEN IF CE_MODULES_DP83815
IF BSP_NOPCIBUS !
IF BSP_NOETHER !
IF BSP_NIC_DP83815

[HKEY_LOCAL_MACHINE\Comm\DP83815]
   "DisplayName"="DP83815 (MacPhyter) Ethernet Driver"
   "Group"="NDIS"
   "ImagePath"="dp83815.dll"
;
; Template the PCI bus driver uses to match DP83815
;

[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\PCI\Template\DP83815]
   "Dll"="NDIS.dll"
   "Class"=dword:02
   "SubClass"=dword:00
   "ProgIF"=dword:0
   "VendorID"=multi_sz:"100B"
   "DeviceID"=multi_sz:"0020"
   "Entry"="NdisPCIBusDeviceInit"
   "Transceiver"=dword:3
;
; Installable shared ISR handler for the DP83815
;
   "IsrDll"="giisr.dll"
   "IsrHandler"="ISRHandler"
   "PortIsIO"=dword:1
   "PortOffset"=dword:0010
   "PortSize"=dword:4
   "PortMask"=dword:f10165

;
; DP83815 specic reg entries..
;

   "Adaptive_IFS"=dword:1
   "BusNumber"=dword:0
   "CardType"=dword:0
   "BusType"=dword:5
   "BusTypeLocal"=dword:5
   "Eid"=dword:0
   "FullDuplex"=dword:2 ;Half-duplex
;  "FullDuplex"=dword:1 ;Full-duplex
   "ForceDpx"=dword:0
   "MACAddressOverride"=dword:0
   "MapRegisters"=dword:40
   "MediaType"=dword:1
   "MsPciScan"=dword:1
   "NetworkAddress"="00-33-33-33-33-33"
   "NumberOfReceiveDescriptors"=dword:10
   "NumberOfTransmitPackets"=dword:10
   "NumberOfMapRegisters"=dword:20
   "NumberOfCoalesceBuffers"=dword:4
   "NumRfd"=dword:10
   "NumTbdPerTcb"=dword:8
   "NumTcb"=dword:10
   "PerfOptims"=dword:2
   "RxDmaCount"=dword:0
   "RxFifo"=dword:8
   "Speed"=dword:1 ; Auto
;  "Speed"=dword:2 ; 10Mbps
;  "Speed"=dword:3 ; 100Mbps
   "Threshold"=dword:10
   "TransmitPadding"=dword:0 ; on
;  "TransmitPadding"=dword:1 ; off
   "TxDmaCount"=dword:0
   "TxFifo"=dword:8
   "Txmitwait"=dword:1
   "Ucode"=dword:0
   "UcodeSW"=dword:1
   "UnderrunRetry"=dword:1
   "SerialNumber"=hex: 00,00,00,00

ENDIF BSP_NIC_DP83815
ENDIF BSP_NOETHER !
ENDIF BSP_NOPCIBUS !
; @CESYSGEN ENDIF CE_MODULES_DP83815


