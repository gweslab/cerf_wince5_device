[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\EventLog\System]
"Output"="File"
"File"="SystemLog.xml"
"Format"="XML"

[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\EventLog\System\EventLog]
"EventMessageFile"="eventlogmsgs.dll"

[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\EventLog\Formatters]
"XML"="\\windows\\eventlog.dll"
"PlainText"="\\windows\\eventlog.dll"

[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\EventLog\Outputters]
"File"="\\windows\\eventlog.dll"
"DebugOut"="\\windows\\eventlog.dll"

; The base directory that EventLogs are written to is specified in EventLogPath.
[HKEY_LOCAL_MACHINE\SYSTEM\ObjectStore]
"EnableEventLog"=dword:1
"EventLogPath"="\\windows"

; @CESYSGEN ENDIF


; @CESYSGEN IF CE_MODULES_WLDAP32
[HKEY_LOCAL_MACHINE\System\CurrentControlSet\Services\LDAP]
"LdapClientIntegrity"=dword:0
; @CESYSGEN ENDIF

; @CESYSGEN IF CE_MODULES_NOTIFY
[HKEY_LOCAL_MACHINE\SYSTEM\Events]
    "system/events/notify/APIReady"="Notifications API set ready"

; @CESYSGEN IF SERVERS_MODULES_SERVICES
IF BSP_NOTIFY_IN_DEVICE
[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\notify]
ENDIF
IF BSP_NOTIFY_IN_DEVICE !
[HKEY_LOCAL_MACHINE\Services\NOTIFY]
ENDIF
; @CESYSGEN ELSE
; @CESYSGEN ENDIF SERVERS_MODULES_SERVICES
   "Dll"="NOTIFY.Dll"
   "Order"=dword:0
   "Keep"=dword:1
   "Prefix"="NFY"
   "Index"=dword:0

; @CESYSGEN ENDIF

;
; IPSECSVC
;
; @CESYSGEN IF CE_MODULES_IPSECSVC

[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\ipsecsvc]
   "Dll"="ipsecsvc.Dll"
   "Order"=dword:8
   "Keep"=dword:1
   "Prefix"="IKE"
   "Index"=dword:0

[HKEY_LOCAL_MACHINE\Comm\IPSec\Policies\Default]
	"inaction"=dword:1
	"outaction"=dword:2
	"auth"=dword:2
	"info"=""
	"mmhash"=dword:7
	"mmenc"=dword:7
	"qmhash"=dword:7
	"qmenc"=dword:4
	"dh"=dword:3
	"protocol"=dword:0
	"flags"=dword:0
	"srcip"="myip"

; @CESYSGEN ENDIF

;
; Credential Manager
;

; @CESYSGEN IF CE_MODULES_CREDMAN

; @CESYSGEN IF SERVERS_MODULES_SERVICES
IF BSP_CREDSVC_IN_DEVICE
[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\credsvc]
ENDIF
IF BSP_CREDSVC_IN_DEVICE !
[HKEY_LOCAL_MACHINE\Services\credsvc]
ENDIF
; @CESYSGEN ELSE
; @CESYSGEN ENDIF SERVERS_MODULES_SERVICES
   "Dll"="credsvc.dll"
   "Order"=dword:8
   "Keep"=dword:1
   "FriendlyName"="CredentialManager"
   "Index"=dword:0
   "Prefix"="CRD"

[HKEY_LOCAL_MACHINE\comm\security\CredMan]

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Creds]
	"FreeSlot"=dword:1
	"NumCreds"=dword:0

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types]

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Primitive]

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Virtual]

;
; Credential Manager Default Type Provider
;

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Primitive\65542]
	"dll"="credprov.dll"
	"flags"=dword:e

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Primitive\65544]
	"dll"="credprov.dll"
	"flags"=dword:e

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Primitive\65546]
	"dll"="credprov.dll"
	"flags"=dword:e

; @CESYSGEN IF CE_MODULES_NTLMSSP

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Primitive\65538]
	"dll"="ntlmssp.dll"
	"flags"=dword:1

; @CESYSGEN IF CE_MODULES_KERBEROS
[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Virtual\65537]
	"ids"="65538,65540"
; @CESYSGEN ELSE
; @CESYSGEN ENDIF

; @CESYSGEN ENDIF

; @CESYSGEN IF CE_MODULES_KERBEROS

[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Primitive\65540]
	"dll"="kerberos.dll"
	"flags"=dword:1

; @CESYSGEN IF CE_MODULES_NTLMSSP
[HKEY_LOCAL_MACHINE\comm\security\CredMan\Types\Virtual\65537]
	"ids"="65538,65540"
; @CESYSGEN ELSE
; @CESYSGEN ENDIF

; @CESYSGEN ENDIF

;
; Credential Manager LASS AE stuff
; AE_CREDMAN
;

[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{125399AC-EF80-4934-9274-186797C0DFAD}]
"FriendlyName"="Credential Manager"
"DisplayText"="Credential Manager"
"AEFrequencyType"=dword:2
"AEFrequencyValue"=dword:3

; @CESYSGEN ENDIF

; @CESYSGEN IF CE_MODULES_LASSD
; Registry values for LASS
;  To have services auto load LASS.
; @CESYSGEN IF SERVERS_MODULES_SERVICES
IF BSP_LASSD_IN_DEVICE
[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\LASSD]
ENDIF
IF BSP_LASSD_IN_DEVICE !
[HKEY_LOCAL_MACHINE\Services\LASSD]
ENDIF
; @CESYSGEN ELSE
; @CESYSGEN ENDIF SERVERS_MODULES_SERVICES
   "Dll"="lassd.dll"
   "Order"=dword:8
   "Keep"=dword:1
   "FriendlyName"="LAS"
   "Index"=dword:0
   "Prefix"="LAS"
;
; System Wide LAP Defines can be found in lass_ae.h
;

; This must be set to every time
;AE_RELOAD_SETTINGS_ENCRYPT_MASTERKEY = {71F82FA4-8589-4516-A0D7-9B7FFCB0C313}
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{71F82FA4-8589-4516-A0D7-9B7FFCB0C313}]
"FriendlyName"="RELOAD LASS CONFIG - Do not change"
"DisplayText"="RELOAD LASS Configuration"
"AEFrequencyType"=dword:0
"AEFrequencyValue"=dword:0

;AE_GUID_STARTUI {1B38A686-7CDC-4017-A5E9-4C6A9DD7E5BA}
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{1B38A686-7CDC-4017-A5E9-4C6A9DD7E5BA}]
"FriendlyName"="Device Startup"
"DisplayText"="System Startup"
; Default: Never get called.
;   When you change the startui code to call V.U. then change this to be 
; AEFrequencyValue of Everytime.
"AEFrequencyType"=dword:0
"AEFrequencyValue"=dword:FFFFFFFF

;AE_GUID_CPLMAIN
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{8FD146DC-623E-499d-AA82-50F31454A161}]
"FriendlyName"="Protected Control Panel Applets"
"DisplayText"="Control Panel"
; Every Time
"AEFrequencyType"=dword:0
"AEFrequencyValue"=dword:0

;AE_TEST1
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{7B6A373C-F16E-4051-8F47-25EFF6F0D532}]
"FriendlyName"="Test AE 1"
"DisplayText"="Test AE 1 - Display Text"
; Every 2 minutes since this AE was hit.
"AEFrequencyType"=dword:3
"AEFrequencyValue"=dword:2

;AE_TEST2
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{578DCD29-9596-42e6-98C3-188C75BB4C04}]
"FriendlyName"="Test AE 2"
"DisplayText"="Test AE 2 - Display Text"
; Every 2 minutes since any AE was hit.
"AEFrequencyType"=dword:2
"AEFrequencyValue"=dword:2

;AE_EVERY_TIME
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{8E6B0AF7-9295-45b4-8B73-55D95304144E}]
"FriendlyName"="AE- Authenticate Every Time"
"DisplayText"="Your App Should overwrite this string - AE_EVERY_TIME."
"AEFrequencyType"=dword:0
"AEFrequencyValue"=dword:0

;AE_DEFAULT_POLICY
[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\AE\{3C2424CC-95D3-4bea-BEB1-ABBBCF15DA96}]
"FriendlyName"="AE- Default Policy"
"DisplayText"="Your App Should overwrite this string - AE_DEFAULT_POLICY"
"AEFrequencyType"=dword:0
"AEFrequencyValue"=dword:0

[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\LAP]
"ActiveLap"="lap_pw"

[HKEY_LOCAL_MACHINE\Comm\Security\LASSD\LAP\lap_pw]
"Dll"="lap_pw.dll"
