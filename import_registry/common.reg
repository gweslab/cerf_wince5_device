IF BSP_NOPCCARD !
; @CESYSGEN IF ATAPI_ATAPI_PCMCIA
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKA]
    "FUNCTION_ID"=dword:4
    "IoBase"=multi_sz:"1f0","3f6"
    "IoLen"=multi_sz:"8","2"
    "IOADDR_HIGHESTBIT_SET"=dword:1 ; Alter the address to highest locate to avoiding conflict with IDE Controller
    "Prefix"="IDE"
    "Dll"="atapi.dll"
    "Order"=dword:6
    "Legacy"=dword:00               ; not legacy
;   "Irq"=dword:00                  ; provided by PC Card bus driver
;   "SysIntr"=dword:00              ; provided by PC Card bus driver
;   "DMAAlignment"=dword:00         ; DMA not supported
    "SoftResetTimeout"=dword:03     ; ATA/ATAPI spec defines 31s ceiling; this is too long
    "StatusPollCycles"=dword:100    ; Status register DRQ/BSY polling; 256 poll cycles
    "StatusPollsPerCycle"=dword:20  ; Status register DRQ/BSY polling; 32 polls per cycle
    "StatusPollCyclePause"=dword:05 ; Status register DRQ/BSY polling; 5 milliseconds between poll cycles
    "SpawnFunction"="CreatePCMCIA"  ; controller-specific instantiation function
    "IsrDll"="giisr.dll"            ; bus-agnostic; installable ISR
    "IsrHandler"="ISRHandler"       ; bus-agnostic; installable ISR
    "DeviceControlOffset"=dword:0   ; base ATA register offset of device control I/O port
    "AlternateStatusOffset"=dword:0 ; base ATA register offset of alternate status I/O port
    "RegisterStride"=dword:01       ; ATA register stride; register block is contiguous
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKA\Device0]
    "IClass"=multi_sz:"{A4E7EDDA-E575-4252-9D6B-4195D48BB865}"
    "Prefix"="DSK"
    "Dll"="atapi.dll"
    "InterruptDriven"=dword:00      ; disable interrupt driven I/O
    "DMA"=dword:00                  ; disable DMA
    "DoubleBufferSize"=dword:10000  ; 128 sector (65536 byte) double buffer
    "DrqDataBlockSize"=dword:200    ; 1 sector (512 byte) DRQ data block
    "WriteCache"=dword:01           ; enable on-disk write cache
    "LookAhead"=dword:01            ; enable on-disk look-ahead
    "DeviceId"=dword:00             ; device 0, i.e., primary master
    "TransferMode"=dword:FF         ; use device default transfer mode (Ultra DMA 3, 4 require 80-conductor cable)
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKB]
    "FUNCTION_ID"=dword:4
    "IoBase"=multi_sz:"170","376"
    "IoLen"=multi_sz:"8","2"
    "IOADDR_HIGHESTBIT_SET"=dword:1 ; Alter the address to highest locate to avoiding conflict with IDE Controller
    "Prefix"="IDE"
    "Dll"="atapi.dll"
    "Order"=dword:6
    "Legacy"=dword:00               ; not legacy
;   "Irq"=dword:00                  ; provided by PC Card bus driver
;   "SysIntr"=dword:00              ; provided by PC Card bus driver
;   "DMAAlignment"=dword:00         ; DMA not supported
    "SoftResetTimeout"=dword:03     ; ATA/ATAPI spec defines 31s ceiling; this is too long
    "StatusPollCycles"=dword:100    ; Status register DRQ/BSY polling; 256 poll cycles
    "StatusPollsPerCycle"=dword:20  ; Status register DRQ/BSY polling; 32 polls per cycle
    "StatusPollCyclePause"=dword:05 ; Status register DRQ/BSY polling; 5 milliseconds between poll cycles
    "SpawnFunction"="CreatePCMCIA"  ; controller-specific instantiation function
    "IsrDll"="giisr.dll"            ; bus-agnostic; installable ISR
    "IsrHandler"="ISRHandler"       ; bus-agnostic; installable ISR
    "DeviceControlOffset"=dword:0   ; base ATA register offset of device control I/O port
    "AlternateStatusOffset"=dword:0 ; base ATA register offset of alternate status I/O port
    "RegisterStride"=dword:01       ; ATA register stride; register block is contiguous
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKB\Device0]
    "IClass"=multi_sz:"{A4E7EDDA-E575-4252-9D6B-4195D48BB865}"
    "Prefix"="DSK"
    "Dll"="atapi.dll"
    "InterruptDriven"=dword:00      ; disable interrupt driven I/O
    "DMA"=dword:00                  ; disable DMA
    "DoubleBufferSize"=dword:10000  ; 128 sector (65536 byte) double buffer
    "DrqDataBlockSize"=dword:200    ; 1 sector (512 byte) DRQ data block
    "WriteCache"=dword:01           ; enable on-disk write cache
    "LookAhead"=dword:01            ; enable on-disk look-ahead
    "DeviceId"=dword:00             ; device 0, i.e., primary master
    "TransferMode"=dword:FF         ; use device default transfer mode (Ultra DMA 3, 4 require 80-conductor cable)
