;; Create IID_IDVDRenderer->AddYourRenderer mappings using this template
;;
;; If you want to select between multiple registered renderers, call
;; IDVDNavigationManager::UseRenderer(name) in your application before SetVolume().
;; If you don't call UseRenderer(), the first registry entry will be used by default.
;;
;; To register a renderer,
;;
;; 1. Create a new entry with the renderer name as the last subkey, like this:
;;       [HKEY_CLASSES_ROOT\CLSID\<CLSID_Metadrvr>\<IID_IDVDRenderer>\<AddYourRendererName>]
;;
;; 2. Add a value named "Renderer" to the subkey.  The data for this value
;;    is the CLSID of the new renderer.
;;
;; 3. Optionally add a value named "BitstreamType" to the subkey. The data for this
;;    value is the bitstream type to be used in IBitstreamProcessor::SetBitstreamType()
;;    during renderer initialization. The default is 0.
;;
;; Example:
;; [HKEY_CLASSES_ROOT\CLSID\{99C99C72-43E8-11d4-84C8-00C04F68EB0F}\{99C99C73-43E8-11d4-84C8-00C04F68EB0F}\MyCoolRenderer]
;; "Renderer"="{99C99C71-43E8-11d4-84C8-00C04F68EB0F}"
;; "BitstreamType"=dword:0


; @CESYSGEN ENDIF

; @CESYSGEN IF DIRECTX_MODULES_TVSHELL
; @CESYSGEN ENDIF

; @CESYSGEN IF DIRECTX_MODULES_STBIHOST
; @CESYSGEN ENDIF

; @CESYSGEN IF DIRECTX_MODULES_MEDIARENDERER

; ---------------------------------------------------------------------------
; Register MediaRenderer
; ---------------------------------------------------------------------------

[HKEY_LOCAL_MACHINE\COMM\UPnPDevices\MediaRenderer]
    "State"=dword:2
    "LifeTime"=dword:800
    "XMLDescFile"="\\windows\\upnp\\MediaRenderer.xml"
    "ProgId"="MediaRenderer.Device"
    "InitString"=""

[HKEY_CLASSES_ROOT\CLSID\{A9A69D51-0EC1-4f84-99FE-05980C10BD28}]
    @="MediaRenderer"

[HKEY_CLASSES_ROOT\CLSID\{A9A69D51-0EC1-4f84-99FE-05980C10BD28}\InprocServer32]
    @="\\windows\\MediaRenderer.dll"
    "ThreadingModel"="both"

[HKEY_CLASSES_ROOT\CLSID\{A9A69D51-0EC1-4f84-99FE-05980C10BD28}\ProgID]
    @="MediaRenderer.Device.1"

[HKEY_CLASSES_ROOT\CLSID\{A9A69D51-0EC1-4f84-99FE-05980C10BD28}\VersionIndependentProgID]
    @="MediaRenderer.Device"

[HKEY_CLASSES_ROOT\MediaRenderer.Device]
    @="MediaRenderer"

[HKEY_CLASSES_ROOT\MediaRenderer.Device\CLSID]
    @="{A9A69D51-0EC1-4f84-99FE-05980C10BD28}"

[HKEY_CLASSES_ROOT\MediaRenderer.Device.1]
    @="MediaRenderer"

[HKEY_CLASSES_ROOT\MediaRenderer.Device.1\CLSID]
    @="{A9A69D51-0EC1-4f84-99FE-05980C10BD28}"

[HKEY_CLASSES_ROOT\TypeLib\{5136F23F-F9FE-4d16-81D4-716E8EFFC4D2}\1.0\0]
    @="\\windows\\MediaRenderer.dll"

[HKEY_CLASSES_ROOT\TypeLib\{5136F23F-F9FE-4d16-81D4-716E8EFFC4D2}\1.0\0\win32]
    @="\\windows\\MediaRenderer.dll"

; @CESYSGEN ENDIF DIRECTX_MODULES_MEDIARENDERER


; ---------------------------------------------------------------------------
